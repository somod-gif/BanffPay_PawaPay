<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <!-- Console appender with correlation ID -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- File appender for webhook audit trail -->
    <appender name="WEBHOOK_AUDIT" class="ch.qos.logback.core.FileAppender">
        <file>logs/webhooks-audit.log</file>
        <append>true</append>
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId}] [%X{pawapayId}] %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- File appender for webhook events only -->
    <logger name="com.banffpay.pawapay.service.WebhookService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="WEBHOOK_AUDIT"/>
    </logger>

    <!-- File appender for reconciliation audit -->
    <logger name="com.banffpay.pawapay.service.ReconciliationService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="WEBHOOK_AUDIT"/>
    </logger>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Dev profile: more verbose logging -->
    <springProfile name="dev">
        <logger name="com.banffpay.pawapay" level="DEBUG"/>
        <logger name="org.springframework.web" level="INFO"/>
    </springProfile>

    <!-- Prod profile: less verbose logging -->
    <springProfile name="prod">
        <logger name="com.banffpay.pawapay" level="INFO"/>
        <logger name="org.springframework.web" level="WARN"/>
    </springProfile>
</configuration>